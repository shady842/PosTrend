{
  "name": "postrend-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -w apps/api build",
    "start:dev": "npm run -w apps/api start:dev",
    "start:admin": "npm run -w apps/admin dev",
    "dev": "concurrently -n api,admin -c blue,green \"npm run -w apps/api start:dev\" \"npm run -w apps/admin dev\"",
    "build:admin": "npm run -w apps/admin build",
    "lint": "npm run -w apps/api lint",
    "test": "npm run -w apps/api test"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
