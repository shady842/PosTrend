{
  "info": {
    "_postman_id": "5f6f037a-bfca-4d8d-9a2d-2cf9ef31fd66",
    "name": "PosTrend Phase 2 SaaS Core",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. List Plans",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/v1/public/plans"
      }
    },
    {
      "name": "2. Signup Tenant",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenant_name\": \"Acme Foods\",\n  \"owner_name\": \"Owner One\",\n  \"email\": \"owner@acme.com\",\n  \"password\": \"secret123\"\n}"
        },
        "url": "{{baseUrl}}/v1/public/signup"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "pm.environment.set('accessToken', body.access_token);",
              "pm.environment.set('refreshToken', body.refresh_token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3. Tenant Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/v1/tenant/me"
      }
    },
    {
      "name": "4. Tenant Subscription",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/v1/tenant/subscription"
      }
    },
    {
      "name": "5. Create Concept",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Second Concept\"\n}"
        },
        "url": "{{baseUrl}}/v1/concepts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "if (body && body.id) pm.environment.set('conceptId', body.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "6. Create Branch",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"concept_id\": \"{{conceptId}}\",\n  \"name\": \"Branch 2\",\n  \"timezone\": \"UTC\",\n  \"currency\": \"USD\"\n}"
        },
        "url": "{{baseUrl}}/v1/branches"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "if (body && body.id) pm.environment.set('branchId', body.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "7. Register Device",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"concept_id\": \"{{conceptId}}\",\n  \"branch_id\": \"{{branchId}}\",\n  \"device_name\": \"POS Front Counter\"\n}"
        },
        "url": "{{baseUrl}}/v1/devices/register"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "pm.environment.set('deviceCode', body.device_code);",
              "pm.environment.set('deviceSecret', body.device_secret);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "8. POS Device Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_code\": \"{{deviceCode}}\",\n  \"device_secret\": \"{{deviceSecret}}\"\n}"
        },
        "url": "{{baseUrl}}/v1/pos/device-login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "pm.environment.set('posAccessToken', body.access_token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "conceptId",
      "value": ""
    },
    {
      "key": "branchId",
      "value": ""
    },
    {
      "key": "deviceCode",
      "value": ""
    },
    {
      "key": "deviceSecret",
      "value": ""
    },
    {
      "key": "posAccessToken",
      "value": ""
    }
  ]
}
