/// Idempotent results for POS device `POST /v1/sync/push` operations (per-tenant keys).
model PosDeviceSyncLedger {
  id             String   @id @default(uuid())
  tenantId       String
  branchId       String
  deviceId       String?
  idempotencyKey String
  domain         String
  opType         String
  result         Json
  createdAt      DateTime @default(now())

  @@unique([tenantId, idempotencyKey])
  @@map("pos_device_sync_ledger")
}

/// Optimistic concurrency + last-mutation time for POS sync (SYNC-5).
model EntityVersion {
  id             String   @id @default(uuid())
  tenantId       String
  branchId       String?
  entityType     String
  entityId       String
  version        Int      @default(0)
  lastMutationAt DateTime @default(now())

  @@unique([tenantId, entityType, entityId])
  @@index([tenantId, entityType])
  @@map("entity_versions")
}

/// Audit trail for sync push / conflict resolution (SYNC-5).
model SyncLog {
  id              String   @id @default(uuid())
  tenantId        String
  branchId        String
  deviceId        String?
  opId            String?
  idempotencyKey  String
  domain          String
  opType          String
  status          String
  clientTimestamp DateTime?
  entityType      String?
  entityId        String?
  serverVersion   Int?
  resolution      String?
  detail          Json?
  createdAt       DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, idempotencyKey])
  @@map("sync_logs")
}

